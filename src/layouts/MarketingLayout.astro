---
import '../styles/workshop.css';
import { getActiveNavItem, workshopNavItems } from '../data/navigation.mjs';

const { title = 'TKE Workshop', description = '面向 TKE 云原生实践的学习路径、操作指南和可执行 Cookbook。' } = Astro.props;
const activeItem = getActiveNavItem(Astro.url.pathname);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="workshop-shell">
      <header class="workshop-nav">
        <div class="workshop-nav__inner">
          <a class="workshop-brand" href="/">
            <span class="workshop-brand__mark">TKE</span>
            <span>TKE Workshop</span>
          </a>
          <nav class="workshop-nav__links" aria-label="主导航">
            {
              workshopNavItems.map((item) => (
                <a href={item.href} aria-current={activeItem?.label === item.label ? 'page' : undefined}>
                  {item.label}
                </a>
              ))
            }
          </nav>
          <details class="workshop-nav__menu">
            <summary>菜单</summary>
            <div class="workshop-nav__menu-panel">
              {
                workshopNavItems.map((item) => (
                  <a href={item.href} aria-current={activeItem?.label === item.label ? 'page' : undefined}>
                    {item.label}
                  </a>
                ))
              }
            </div>
          </details>
          <a class="workshop-button" href="https://github.com/tke-workshop/tke-workshop.github.io">GitHub</a>
        </div>
      </header>
      <main class="workshop-main">
        <slot />
      </main>
      <footer class="workshop-footer">
        <div class="workshop-footer__inner">
          Copyright &copy; 2024-2026 Tencent Cloud. Built with Astro and Starlight.
        </div>
      </footer>
    </div>
  </body>
</html>
