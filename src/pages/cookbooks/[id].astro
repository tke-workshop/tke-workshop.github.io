---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import { cookbooks, getCookbook } from '../../data/cookbooks.js';

export function getStaticPaths() {
  return cookbooks.map((cookbook) => ({
    params: { id: cookbook.id },
  }));
}

const cookbook = getCookbook(Astro.params.id ?? '');

if (!cookbook) {
  throw new Error(`Cookbook not found: ${Astro.params.id}`);
}

function getFileHref(file) {
  return typeof file === 'string'
    ? `https://github.com/tke-workshop/tke-workshop.github.io/blob/main/${file}`
    : file.href;
}

function getFileLabel(file) {
  return typeof file === 'string' ? file : file.label;
}
---

<MarketingLayout title={`${cookbook.title} - TKE Cookbook`}>
  <section class="workshop-section">
    <a class="workshop-button" href="/cookbooks/">返回 Cookbooks</a>
    <div style="margin-top: 24px;">
      <span class="workshop-kicker">{cookbook.category} recipe</span>
      <h1 style="max-width: 820px; margin: 0; font-size: clamp(2.1rem, 5vw, 4rem); line-height: 1.05;">
        <span aria-hidden="true">{cookbook.icon}</span> {cookbook.title}
      </h1>
      <p style="max-width: 760px; color: var(--tke-muted); font-size: 1.1rem; line-height: 1.8;">
        {cookbook.description}
      </p>
      <div class="recipe-meta">
        <span class="pill">{cookbook.language}</span>
        <span class="pill">{cookbook.estimatedTime}</span>
        <span class="pill">{cookbook.verified ? 'Verified' : 'Draft'}</span>
        <span class="pill pill--risk">风险：{cookbook.risk.level}</span>
        {cookbook.tags.map((tag) => <span class="pill">{tag}</span>)}
      </div>
    </div>
  </section>

  <div class="recipe-layout">
    <article>
      <section class="recipe-section recipe-section--risk">
        <h2>风险与费用提示</h2>
        <div class="recipe-risk-grid">
          <div>
            <span class="recipe-eyebrow">资源影响</span>
            <strong>{cookbook.risk.resourceImpact}</strong>
          </div>
          <div>
            <span class="recipe-eyebrow">费用影响</span>
            <strong>{cookbook.risk.cost}</strong>
          </div>
        </div>
        <p>{cookbook.risk.notice}</p>
      </section>

      <section class="recipe-section">
        <h2>执行拓扑</h2>
        <div class="service-map" aria-label={`${cookbook.title} 执行拓扑`}>
          {
            cookbook.services.map((service, index) => (
              <>
                <div class="service-node">
                  <span class="service-node__icon" aria-hidden="true">{service.icon}</span>
                  <span>{service.label}</span>
                </div>
                {index < cookbook.services.length - 1 && (
                  <span class="service-map__arrow" aria-hidden="true">→</span>
                )}
              </>
            ))
          }
        </div>
      </section>

      <section class="recipe-section">
        <h2>前置条件</h2>
        <ul>
          {cookbook.prerequisites.map((item) => <li>{item}</li>)}
        </ul>
      </section>

      <section class="recipe-section">
        <h2>参数表</h2>
        <div class="recipe-table-wrap">
          <table class="recipe-table">
            <thead>
              <tr>
                <th>参数</th>
                <th>必填</th>
                <th>示例</th>
                <th>说明</th>
              </tr>
            </thead>
            <tbody>
              {
                cookbook.parameters.map((parameter) => (
                  <tr>
                    <td><code>{parameter.name}</code></td>
                    <td>{parameter.required ? '是' : '否'}</td>
                    <td><code>{parameter.example}</code></td>
                    <td>{parameter.description}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </section>

      <section class="recipe-section">
        <h2>执行命令</h2>
        <div class="recipe-command-list">
          {
            cookbook.commands.map((command, index) => (
              <div class="recipe-command">
                <div class="recipe-command__head">
                  <span>Step {index + 1}</span>
                  <button class="copy-button" type="button" data-copy={command}>复制</button>
                </div>
                <pre class="command-block"><code>{command}</code></pre>
              </div>
            ))
          }
        </div>
      </section>

      <section class="recipe-section">
        <h2>验证步骤</h2>
        <div class="recipe-command-list">
          {
            cookbook.verification.map((item, index) => (
              <div class="recipe-command">
                <div class="recipe-command__head">
                  <span>Check {index + 1}</span>
                  <button class="copy-button" type="button" data-copy={item}>复制</button>
                </div>
                <pre class="command-block"><code>{item}</code></pre>
              </div>
            ))
          }
        </div>
      </section>

      <section class="recipe-section">
        <h2>清理步骤</h2>
        <ol>
          {cookbook.cleanup.map((item) => <li>{item}</li>)}
        </ol>
      </section>

      <section class="recipe-section">
        <h2>Agent Prompt</h2>
        <div class="recipe-command">
          <div class="recipe-command__head">
            <span>Prompt</span>
            <button class="copy-button" type="button" data-copy={cookbook.prompt}>复制 Prompt</button>
          </div>
          <p>{cookbook.prompt}</p>
        </div>
      </section>
    </article>

    <aside class="recipe-aside">
      <section class="recipe-section">
        <h2>来源仓库</h2>
        <ul>
          <li>
            <a href={cookbook.source.href}>{cookbook.source.repo}</a>
          </li>
          <li>Branch: <code>{cookbook.source.branch}</code></li>
          <li>Path: <code>{cookbook.source.path || '/'}</code></li>
        </ul>
      </section>

      <section class="recipe-section">
        <h2>相关文档</h2>
        <ul>
          {
            cookbook.relatedDocs.map((doc) => (
              <li>
                <a href={doc.href}>{doc.label}</a>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="recipe-section">
        <h2>相关文件</h2>
        <ul>
          {
            cookbook.files.map((file) => (
              <li>
                <a href={getFileHref(file)}>{getFileLabel(file)}</a>
              </li>
            ))
          }
        </ul>
      </section>
    </aside>
  </div>

  <script>
    async function copyText(text) {
      if (navigator.clipboard?.writeText) {
        try {
          await navigator.clipboard.writeText(text);
          return;
        } catch {
          // Fall back to a temporary textarea for browsers that block clipboard writes.
        }
      }

      const textarea = document.createElement('textarea');
      textarea.value = text;
      textarea.setAttribute('readonly', '');
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.append(textarea);
      textarea.select();
      const copied = document.execCommand('copy');
      textarea.remove();
      if (!copied) throw new Error('Copy failed');
    }

    document.addEventListener('click', async (event) => {
      const button = event.target instanceof HTMLElement && event.target.closest('.copy-button');
      if (!(button instanceof HTMLButtonElement)) return;

      const text = button.dataset.copy;
      if (!text) return;

      const originalText = button.textContent;
      try {
        await copyText(text);
        button.textContent = '已复制';
      } catch {
        button.textContent = '请手动复制';
      }
      window.setTimeout(() => {
        button.textContent = originalText;
      }, 1600);
    });
  </script>
</MarketingLayout>
